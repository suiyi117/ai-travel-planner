# 高德地图 Web 服务 API Key
# 申请地址: https://console.amap.com/dev/key/app
AMAP_KEY=你的高德API Key

# AI API 配置 (OpenAI 兼容接口)
# 支持 OpenAI / 通义千问(DashScope) / DeepSeek / 智谱GLM 等
AI_API_KEY=你的AI API Key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# 如果使用通义千问:
# AI_API_KEY=sk-xxx
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus

# 如果使用 DeepSeek:
# AI_API_KEY=sk-xxx
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# ===== 交通查询 API（可选） =====
# 火车票查询使用 12306 公开接口，无需配置

# 航班查询 API（聚合数据）
# 申请地址: https://www.juhe.cn/docs/api/id/45
# 未配置时使用内置典型航线数据
# JUHE_FLIGHT_API_KEY=你的聚合数据API Key
